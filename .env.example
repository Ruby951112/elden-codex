# ============================================================
# Elden Codex — Environment Variables
# ============================================================
# Copy this file to .env.local for local dev:
#   cp .env.example .env.local
#
# In Vercel, add these via Project Settings → Environment Variables
# ============================================================


# ──────────────────────────────────────────────────────────
# REQUIRED — Anthropic API (for content generation pipeline)
# ──────────────────────────────────────────────────────────
# Get a key at: https://console.anthropic.com
# Cost: ~$20-50 to generate all 165 bosses × 2 languages
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ──────────────────────────────────────────────────────────
# REQUIRED — Contact form (Resend)
# ──────────────────────────────────────────────────────────
# Get free API key at: https://resend.com (3,000 emails/month free)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Your real email — where feedback gets delivered
# Auto-tagged subject: "[Elden Codex] Feedback from <name>"
# Use a Gmail filter to route into a sub-folder for this project
CONTACT_RECIPIENT_EMAIL=your-real-email@gmail.com

# Sender email — must be a verified domain in Resend
# For dev/testing, use Resend's default: onboarding@resend.dev
# For production, set up DNS verification at resend.com → Domains
CONTACT_FROM_EMAIL=hello@yourdomain.com


# ──────────────────────────────────────────────────────────
# REQUIRED — Site domain (for SEO, sitemap, OG tags)
# ──────────────────────────────────────────────────────────
# DO NOT include https:// or trailing slash
NEXT_PUBLIC_SITE_DOMAIN=eldencodex.com


# ──────────────────────────────────────────────────────────
# OPTIONAL — Monetization: Google AdSense
# ──────────────────────────────────────────────────────────
# Apply at: https://adsense.google.com (need 1+ months of content first)
# Set to 'true' once approved to enable ads
NEXT_PUBLIC_ADSENSE_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# Specific ad unit slot IDs (created in AdSense dashboard)
NEXT_PUBLIC_ADSENSE_SLOT_INARTICLE=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=


# ──────────────────────────────────────────────────────────
# OPTIONAL — Monetization: Amazon Associates
# ──────────────────────────────────────────────────────────
# Apply at: https://affiliate-program.amazon.com (no traffic requirement initially)
# Tag format: yourtag-20 (US) or yourtag-21 (UK), etc.
NEXT_PUBLIC_AMAZON_ENABLED=false
NEXT_PUBLIC_AMAZON_TAG=yourtag-20


# ──────────────────────────────────────────────────────────
# OPTIONAL — Monetization: Steam Key Affiliates
# ──────────────────────────────────────────────────────────
# Fanatical: https://www.fanatical.com/affiliates  (5-15% commission)
# GreenManGaming: https://greenmangaming.com/affiliates
# Eneba: https://www.eneba.com/affiliates
NEXT_PUBLIC_STEAM_KEY_ENABLED=false
NEXT_PUBLIC_FANATICAL_ID=
NEXT_PUBLIC_GMG_ID=
NEXT_PUBLIC_ENEBA_ID=


# ──────────────────────────────────────────────────────────
# OPTIONAL — Analytics (Vercel Analytics auto-loads if deployed on Vercel)
# ──────────────────────────────────────────────────────────
# No env vars needed — just deploy to Vercel and analytics activate.
# For Google Analytics, add NEXT_PUBLIC_GA_ID and uncomment in app/layout.tsx
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
